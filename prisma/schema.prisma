generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String                    @unique
  firstName               String                    @map("first_name") @db.VarChar(50)
  lastName                String                    @map("last_name") @db.VarChar(50)
  role                    Role                      @default(user)
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  confidenceScore         Float                     @default(0.0) @map("confidence_score")
  passwordHash            String                    @map("password_hash") @db.VarChar(255)
  alert_subscriptions     alert_subscriptions[]
  checkpointAuditLogs     CheckpointAuditLog[]      @relation("CheckpointAuditActor")
  checkpointStatusHistory CheckpointStatusHistory[] @relation("CheckpointStatusHistoryUser")
  checkpoint              Checkpoint[]
  statusHistory           IncidentStatusHistory[]
  moderatedIncidents      Incident[]                @relation("IncidentModerated")
  reportedIncidents       Incident[]                @relation("IncidentReporter")
  moderationAuditLogs     ModerationAuditLog[]      @relation("ModerationAuditModerator")
  refreshTokens           RefreshToken[]
  reportVotes             ReportVote[]              @relation("UserVotes")
  reports                 Report[]                  @relation("UserReports")
  RouteHistory            RouteHistory[]

  @@map("users")
}

model Checkpoint {
  id            Int                       @id @default(autoincrement())
  name          String                    @db.VarChar(100)
  description   String?
  latitude      Decimal                   @db.Decimal(10, 6)
  longitude     Decimal                   @db.Decimal(10, 6)
  status        TrafficStatus             @default(open)
  createdBy     String?                   @map("created_by") @db.Uuid
  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")
  area          String?                   @db.VarChar(100)
  city          String?                   @db.VarChar(255)
  road          String?                   @db.VarChar(255)
  auditLogs     CheckpointAuditLog[]
  statusHistory CheckpointStatusHistory[]
  user          User?                     @relation(fields: [createdBy], references: [id])
  incidents     Incident[]
  reports       Report[]

  @@index([latitude, longitude], map: "idx_checkpoints_location")
  @@index([city], map: "idx_checkpoints_city")
  @@index([area], map: "idx_checkpoints_area")
  @@map("checkpoints")
}

model CheckpointStatusHistory {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  checkpointId Int           @map("checkpoint_id")
  changedBy    String?       @map("changed_by") @db.Uuid
  oldStatus    TrafficStatus @map("old_status")
  newStatus    TrafficStatus @map("new_status")
  notes        String?
  changedAt    DateTime      @default(now()) @map("changed_at") @db.Timestamptz(6)
  user         User?         @relation("CheckpointStatusHistoryUser", fields: [changedBy], references: [id])
  checkpoint   Checkpoint    @relation(fields: [checkpointId], references: [id], onDelete: Cascade)

  @@index([checkpointId], map: "idx_checkpoint_status_history_checkpoint_id")
  @@index([changedBy], map: "idx_checkpoint_status_history_changed_by")
  @@index([changedAt(sort: Desc)], map: "idx_checkpoint_status_history_changed_at")
  @@map("checkpoint_status_history")
}

model CheckpointAuditLog {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  checkpointId    Int                   @map("checkpoint_id")
  checkpointRefId Int?                  @map("checkpoint_ref_id")
  actorId         String?               @map("actor_id") @db.Uuid
  action          CheckpointAuditAction
  reason          String?
  oldValues       Json?                 @map("old_values")
  newValues       Json?                 @map("new_values")
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  actor           User?                 @relation("CheckpointAuditActor", fields: [actorId], references: [id])
  checkpoint      Checkpoint?           @relation(fields: [checkpointRefId], references: [id])

  @@index([checkpointId], map: "idx_checkpoint_audit_checkpoint_id")
  @@index([checkpointRefId], map: "idx_checkpoint_audit_checkpoint_ref_id")
  @@index([actorId], map: "idx_checkpoint_audit_actor_id")
  @@index([action], map: "idx_checkpoint_audit_action")
  @@index([createdAt(sort: Desc)], map: "idx_checkpoint_audit_created_at")
  @@map("checkpoint_audit_log")
}

model RefreshToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime @map("expires_at")
  deviceId   String   @map("device_id") @db.VarChar(255)
  deviceName String   @default("Unknown Device") @map("device_name") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Report {
  id                       Int                  @id @default(autoincrement())
  userId                   String?              @map("user_id") @db.Uuid
  locationLat              Decimal              @map("location_lat") @db.Decimal(10, 8)
  locationLng              Decimal              @map("location_lng") @db.Decimal(11, 8)
  area                     String?              @db.VarChar(255)
  type                     IncidentType
  description              String
  confidenceScore          Float                @default(0) @map("confidence_score")
  status                   ReportStatus         @default(pending)
  moderatedBy              String?              @map("moderated_by") @db.Uuid
  moderatedAt              DateTime?            @map("moderated_at") @db.Timestamptz(6)
  rejectReason             String?              @map("reject_reason")
  duplicateOf              Int?                 @map("duplicate_of")
  createdAt                DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  severity                 IncidentSeverity     @default(low)
  incidentId               Int?                 @map("incident_id")
  checkpointId             Int?                 @map("checkpoint_id")
  city                     String?              @db.VarChar(255)
  proposedCheckpointStatus TrafficStatus?       @map("proposed_checkpoint_status")
  road                     String?              @db.VarChar(255)
  auditLogs                ModerationAuditLog[]
  votes                    ReportVote[]
  checkpoint               Checkpoint?          @relation(fields: [checkpointId], references: [id])
  original                 Report?              @relation("ReportDuplicates", fields: [duplicateOf], references: [id])
  duplicates               Report[]             @relation("ReportDuplicates")
  incident                 Incident?            @relation(fields: [incidentId], references: [id])
  user                     User?                @relation("UserReports", fields: [userId], references: [id])

  @@index([incidentId])
  @@index([userId], map: "idx_reports_user_id")
  @@index([status], map: "idx_reports_status")
  @@index([type], map: "idx_reports_type")
  @@index([duplicateOf], map: "idx_reports_duplicate_of")
  @@index([checkpointId], map: "idx_reports_checkpoint_id")
  @@index([type, checkpointId, proposedCheckpointStatus, status, createdAt], map: "idx_reports_checkpoint_status_dedup")
  @@index([locationLat, locationLng], map: "idx_reports_location")
  @@index([city], map: "idx_reports_city")
  @@index([area], map: "idx_reports_area")
  @@index([road], map: "idx_reports_road")
  @@index([createdAt], map: "idx_reports_created_at")
  @@map("reports")
}

model Incident {
  id            Int                     @id @default(autoincrement())
  checkpointId  Int?                    @map("checkpoint_id")
  reportedBy    String                  @map("reported_by") @db.Uuid
  locationLat   Decimal                 @map("location_lat") @db.Decimal(10, 8)
  locationLng   Decimal                 @map("location_lng") @db.Decimal(11, 8)
  area          String?                 @db.VarChar(255)
  type          IncidentType
  severity      IncidentSeverity
  description   String?
  resolvedAt    DateTime?               @map("resolved_at")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")
  trafficStatus TrafficStatus           @default(unknown) @map("traffic_status")
  status        IncidentStatus          @default(pending)
  moderatedAt   DateTime?               @map("moderated_at")
  moderatedBy   String?                 @map("moderated_by") @db.Uuid
  city          String?                 @db.VarChar(255)
  road          String?                 @db.VarChar(255)
  alerts        alerts[]
  statusHistory IncidentStatusHistory[]
  checkpoint    Checkpoint?             @relation(fields: [checkpointId], references: [id])
  moderator     User?                   @relation("IncidentModerated", fields: [moderatedBy], references: [id])
  reporter      User                    @relation("IncidentReporter", fields: [reportedBy], references: [id], onDelete: Cascade)
  reports       Report[]

  @@index([checkpointId], map: "idx_incidents_checkpoint_id")
  @@index([type], map: "idx_incidents_type")
  @@index([severity], map: "idx_incidents_severity")
  @@index([reportedBy], map: "idx_incidents_reported_by")
  @@index([moderatedBy], map: "idx_incidents_moderated_by")
  @@index([city], map: "idx_incidents_city")
  @@index([area], map: "idx_incidents_area")
  @@index([road], map: "idx_incidents_road")
  @@index([createdAt(sort: Desc)], map: "idx_incidents_created_at")
  @@map("incidents")
}

model IncidentStatusHistory {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  incidentId Int            @map("incident_id")
  changedBy  String         @map("changed_by") @db.Uuid
  notes      String?
  oldValues  Json?          @map("old_values")
  newValues  Json?          @map("new_values")
  changedAt  DateTime       @default(now()) @db.Timestamptz(6)
  oldStatus  IncidentStatus @map("old_status")
  newStatus  IncidentStatus @map("new_status")
  user       User           @relation(fields: [changedBy], references: [id], onDelete: Cascade)
  incident   Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@map("incident_status_history")
}

model ReportVote {
  id        Int       @id @default(autoincrement())
  reportId  Int       @map("report_id")
  userId    String    @map("user_id") @db.Uuid
  vote      VoteValue
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  report    Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user      User      @relation("UserVotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reportId, userId], map: "unique_user_vote")
  @@index([reportId], map: "idx_report_votes_report_id")
  @@index([userId], map: "idx_report_votes_user_id")
  @@map("report_votes")
}

model ModerationAuditLog {
  id          Int              @id @default(autoincrement())
  reportId    Int              @map("report_id")
  moderatorId String?          @map("moderator_id") @db.Uuid
  action      ModerationAction
  reason      String?
  createdAt   DateTime         @default(now()) @map("created_at")
  moderator   User?            @relation("ModerationAuditModerator", fields: [moderatorId], references: [id])
  report      Report           @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId], map: "idx_mod_audit_report_id")
  @@index([moderatorId], map: "idx_mod_audit_moderator_id")
  @@index([createdAt(sort: Desc)], map: "idx_mod_audit_created_at")
  @@map("moderation_audit_log")
}

model RouteCache {
  id           Int      @id @default(autoincrement())
  cacheKey     String   @unique @map("cache_key") @db.VarChar(64)
  fromLat      Decimal  @map("from_lat") @db.Decimal(10, 8)
  fromLng      Decimal  @map("from_lng") @db.Decimal(11, 8)
  toLat        Decimal  @map("to_lat") @db.Decimal(10, 8)
  toLng        Decimal  @map("to_lng") @db.Decimal(11, 8)
  responseData Json     @map("response_data")
  hitCount     Int      @default(1) @map("hit_count")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([cacheKey])
  @@index([expiresAt])
  @@map("route_cache")
}

model ExternalApiLog {
  id             Int        @id @default(autoincrement())
  service        ApiService
  endpoint       String     @db.VarChar(255)
  statusCode     Int?       @map("status_code")
  responseTimeMs Int?       @map("response_time_ms")
  isFallback     Boolean    @default(false) @map("is_fallback")
  errorMessage   String?    @map("error_message")
  createdAt      DateTime   @default(now()) @map("created_at")

  @@index([service])
  @@index([isFallback])
  @@index([createdAt(sort: Desc)])
  @@map("external_api_logs")
}

model RouteHistory {
  id                   Int      @id @default(autoincrement())
  userId               String   @map("user_id") @db.Uuid
  fromLat              Decimal  @map("from_lat") @db.Decimal(10, 8)
  fromLng              Decimal  @map("from_lng") @db.Decimal(11, 8)
  toLat                Decimal  @map("to_lat") @db.Decimal(10, 8)
  toLng                Decimal  @map("to_lng") @db.Decimal(11, 8)
  distanceKm           Decimal  @map("distance_km") @db.Decimal(8, 2)
  baseDurationMinutes  Decimal  @map("base_duration_minutes") @db.Decimal(8, 2)
  finalDurationMinutes Decimal  @map("final_duration_minutes") @db.Decimal(8, 2)
  totalDelayMinutes    Int      @map("total_delay_minutes")
  isFallback           Boolean  @default(false) @map("is_fallback")
  createdAt            DateTime @default(now()) @map("created_at")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_route_history_user_id")
  @@index([createdAt(sort: Desc)], map: "idx_route_history_created_at")
  @@map("route_history")
}

model alert_subscriptions {
  id         Int      @id @default(autoincrement())
  user_id    String   @db.Uuid
  area_lat   Decimal  @db.Decimal(10, 8)
  area_lng   Decimal  @db.Decimal(11, 8)
  radius_km  Decimal  @default(10.0) @db.Decimal(5, 2)
  category   String   @default("all")
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  alerts     alerts[]

  @@index([user_id], map: "idx_alert_subscriptions_user_id")
}

model alerts {
  id                  Int                 @id @default(autoincrement())
  incident_id         Int
  subscription_id     Int
  status              String              @default("pending")
  sent_at             DateTime?
  created_at          DateTime            @default(now())
  incidents           Incident            @relation(fields: [incident_id], references: [id], onDelete: Cascade)
  alert_subscriptions alert_subscriptions @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@index([incident_id], map: "idx_alerts_incident_id")
  @@index([subscription_id], map: "idx_alerts_subscription_id")
}

enum Role {
  user
  moderator
  admin
}

enum CheckpointAuditAction {
  created
  updated
  deleted
}

enum ReportStatus {
  pending
  verified
  rejected
}

enum IncidentType {
  closure
  delay
  accident
  military_activity
  weather_hazard
  road_damage
  protest
  construction
  other
  checkpoint_status_update
}

enum IncidentSeverity {
  low
  medium
  high
  critical
}

enum IncidentStatus {
  pending
  verified
  closed
  rejected
}

enum TrafficStatus {
  open
  closed
  slow
  unknown
}

enum VoteValue {
  up
  down
}

enum ModerationAction {
  approved
  rejected
}

enum ApiService {
  osrm
  openweathermap

  @@map("api_service")
}
