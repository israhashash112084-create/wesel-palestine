// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {

  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  email        String @unique
  passwordHash String @map("password_hash") @db.VarChar(255)

  firstName String @map("first_name") @db.VarChar(50)
  lastName  String @map("last_name") @db.VarChar(50)

  role            Role  @default(user)
  confidenceScore Float @default(0.0) @map("confidence_score")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  checkpoints   Checkpoints[]
  refreshTokens RefreshToken[]
  statusHistory IncidentStatusHistory[]

  reports             Report[]             @relation("UserReports")
  reportVotes         ReportVote[]         @relation("UserVotes")
  moderationAuditLogs ModerationAuditLog[] @relation("ModerationAuditModerator")
  reportedIncidents   Incidents[]          @relation("IncidentReporter")
  moderadedIncidents  Incidents[]          @relation("IncidentModerad")

  @@map("users")
}

enum Role {
  user
  moderator
  admin
}

model Checkpoints {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(100)
  areaName    String?       @map("area_name") @db.VarChar(100)
  description String?       @db.Text
  latitude    Decimal       @db.Decimal(10, 6)
  longitude   Decimal       @db.Decimal(10, 6)
  status      TrafficStatus @default(open)
  createdBy   String?       @map("created_by") @db.Uuid
  user        User?         @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  incidents   Incidents[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("checkpoints")
}

model RefreshToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime @map("expires_at")
  deviceId   String   @map("device_id") @db.VarChar(255)
  deviceName String   @default("Unknown Device") @map("device_name") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  lastUsedAt DateTime @default(now()) @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Report {
  id              Int          @id @default(autoincrement())
  userId          String?      @map("user_id") @db.Uuid
  incidentId      Int?         @map("incident_id")
  locationLat     Decimal      @map("location_lat") @db.Decimal(10, 8)
  locationLng     Decimal      @map("location_lng") @db.Decimal(11, 8)
  area            String?      @db.VarChar(255)
  type            IncidentType
  severity        IncidentSeverity @default(low)
  description     String       @db.Text
  confidenceScore Int          @default(0) @map("confidence_score")
  status          ReportStatus @default(pending)
  moderatedBy     String?      @map("moderated_by") @db.Uuid
  moderatedAt     DateTime?    @map("moderated_at") @db.Timestamptz(6)
  rejectReason    String?      @map("reject_reason") @db.Text
  duplicateOf     Int?         @map("duplicate_of")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6) 

  original   Report?  @relation("ReportDuplicates", fields: [duplicateOf], references: [id], onDelete: SetNull)
  duplicates Report[] @relation("ReportDuplicates")

  user      User? @relation("UserReports", fields: [userId], references: [id], onDelete: SetNull)
  incident  Incidents? @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  votes     ReportVote[]
  auditLogs ModerationAuditLog[]

  @@index([incidentId])
  @@index([userId], map: "idx_reports_user_id")
  @@index([status], map: "idx_reports_status")
  @@index([type], map: "idx_reports_type")
  @@index([duplicateOf], map: "idx_reports_duplicate_of")
  @@index([locationLat, locationLng], map: "idx_reports_location")
  @@index([createdAt], map: "idx_reports_created_at")

  @@map("reports")
}

enum ReportStatus {
  pending
  verified
  rejected
}

model Incidents {
  id           Int  @id @default(autoincrement())
  checkpointId Int? @map("checkpoint_id")

  reportedBy  String  @map("reported_by") @db.Uuid
  moderatedBy String? @map("moderade_by") @db.Uuid

  locationLat Decimal @map("location_lat") @db.Decimal(10, 8)
  locationLng Decimal @map("location_lng") @db.Decimal(11, 8)

  area String? @db.VarChar(255)

  type        IncidentType
  severity    IncidentSeverity
  description String?          @db.Text

  trafficStatus TrafficStatus  @default(unknown) @map("traffic_status")
  status        IncidentStatus @default(pending)

  moderatedAt DateTime? @map("moderaded_at")
  resolvedAt  DateTime? @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  checkpoint Checkpoints? @relation(fields: [checkpointId], references: [id], onDelete: SetNull)
  reporter   User         @relation("IncidentReporter", fields: [reportedBy], references: [id], onDelete: Cascade)
  moderad    User?        @relation("IncidentModerad", fields: [moderatedBy], references: [id], onDelete: SetNull)

  reports Report[]

  statusHistory IncidentStatusHistory[]

  @@index([checkpointId], map: "idx_incidents_checkpoint_id")
  @@index([type], map: "idx_incidents_type")
  @@index([severity], map: "idx_incidents_severity")
  @@index([reportedBy], map: "idx_incidents_reported_by")
  @@index([moderatedBy], map: "idx_incidents_verified_by")
  @@index([createdAt(sort: Desc)], map: "idx_incidents_created_at")

  @@map("incidents")
}

model IncidentStatusHistory {

  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  incidentId Int    @map("incident_id")
  changedBy  String @map("changed_by") @db.Uuid

  oldStatus TrafficStatus @map("old_status")
  newStatus TrafficStatus @map("new_status")

  changedAt DateTime @default(now()) @db.Timestamptz(6)
  notes     String?
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")

  incident Incidents @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [changedBy], references: [id], onDelete: Cascade)

  @@map("incident_status_history")
}

enum IncidentType {
  closure
  delay
  accident
  military_activity
  weather_hazard
  road_damage
  protest
  construction
  other
}

enum IncidentSeverity {
  low
  medium
  high
  critical
}

enum IncidentStatus {
  pending
  verified
  closed
}

enum TrafficStatus {
  open
  closed
  slow
  unknown
}

model ReportVote {
  id        Int       @id @default(autoincrement())
  reportId  Int       @map("report_id")
  userId    String    @map("user_id") @db.Uuid
  vote      VoteValue
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user   User   @relation("UserVotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reportId, userId], map: "unique_user_vote")
  @@index([reportId], map: "idx_report_votes_report_id")
  @@index([userId], map: "idx_report_votes_user_id")
  @@map("report_votes")
}

enum VoteValue {
  up
  down
}

model ModerationAuditLog {
  id          Int              @id @default(autoincrement())
  reportId    Int              @map("report_id")
  moderatorId String?          @map("moderator_id") @db.Uuid
  action      ModerationAction
  reason      String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")

  report    Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  moderator User?  @relation("ModerationAuditModerator", fields: [moderatorId], references: [id], onDelete: SetNull)

  @@index([reportId], map: "idx_mod_audit_report_id")
  @@index([moderatorId], map: "idx_mod_audit_moderator_id")
  @@index([createdAt(sort: Desc)], map: "idx_mod_audit_created_at")
  @@map("moderation_audit_log")
}

enum ModerationAction {
  approved
  rejected
}
