# .env.example

# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wasel_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_SSL=false
DB_POOL_MAX=10

# JWT Configuration
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_RANDOM_SECRET_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis Configuration (used for caching AND job queues via BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS (production only — comma-separated origins)
ALLOWED_ORIGINS=https://your-frontend.com

# Prisma (set DATABASE_URL for Prisma Client)
DATABASE_URL="postgres://postgres:your_db_password_here@localhost:5432/wasel_db"

# Prisma (set DIRECT_URL for direct connections, bypassing pgBouncer)
# Direct connection to the database. Used for migrations
DIRECT_URL="postgres://postgres:your_db_password_here@localhost:5432/wasel_db"

# External APIs
WEATHER_API_KEY=your-weather-api-key
WEATHER_API_URL=https://api.weatherapi.com/v1
ROUTING_API_KEY=your-routing-api-key
ROUTING_API_URL=https://api.openrouteservice.org/v2

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info